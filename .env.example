# You must use one of the LLM provider options below, otherwise the backend will not start

# OpenRouter
# LLM_PROVIDER=openai_compatible
# LLM_API_BASE=https://openrouter.ai/api/v1
# LLM_API_KEY=
# LLM_MODEL=openai/gpt-oss-20b:free # or liquid/lfm-2.5-1.2b-instruct:free

# groq
# GROQ_API_KEY=

# Debug variables
DEBUG=false # true/false

# Docker
# BASE_IMAGE=localhost/automaestro/base:latest # ghcr.io/cedarvillecs/automaestro-base:latest

# Frontend
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3030

# Backend
BACKEND_HOST=192.168.21.25
BACKEND_PORT=3000

# MCP Server
MCP_HOST=192.168.21.50
MCP_PORT=5000

# Database
DATABASE_HOST=192.168.21.20
DATABASE_PORT=10260
DATABASE_NAME=main
DATABASE_USER=user
DATABASE_PASS=password
DATABASE_INSECURE_TLS=true # required for the current docker environment
# DATABASE_URL="mongodb://user:password@192.168.21.20:10260/main?tls=true&tlsInsecure=true" # alternative url when needed

# Agent Execution Settings
AUTO_EXECUTE_COMMANDS=true  # Set to false to only generate commands without executing
DEFAULT_EXECUTOR_CONTAINER=A-10.8.0.99  # Container name for command execution
